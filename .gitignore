# ==========================================
# Swedish Stock Earnings Predictor - GitHub .gitignore
# ==========================================

# Environment variables & secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# Python bytecode & cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Operating System & IDEs
.DS_Store
**/.DS_Store
.vscode/
.idea/
.claude/
.gemini/
*.swp
*.swo
*~

# Logs (keep logs directory structure via .gitkeep)
logs/*.log
*.log
!logs/.gitkeep

# Databases
data/*.db
data/*.db-journal
data/*.db-wal
data/*.sqlite
data/*.sqlite3

# Generated outputs, plots, and grid search results
data/grid_search/
data/plots/
data/exports/
data/backup/
data/*.csv.bak
*.png

# Testing & Coverage
.pytest_cache/
.coverage
htmlcov/
.ipynb_checkpoints/
